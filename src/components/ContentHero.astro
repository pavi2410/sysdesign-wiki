---
interface Props {
  breadcrumb: string;
  breadcrumbHref: string;
  categoryLabel: string;
  categoryColorClass: string;
  title: string;
  tagline: string;
  tags: string[];
}

const { breadcrumb, breadcrumbHref, categoryLabel, categoryColorClass, title, tagline, tags } = Astro.props;
---

<section class="bg-paper-warm border-b border-border relative">
  <div class="absolute inset-x-0 top-0 h-px bg-accent/30"></div>
  <div class="max-w-5xl mx-auto px-6 pt-12 pb-10">
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <a href={breadcrumbHref} class="font-mono text-xs text-ink-muted hover:text-accent transition-colors">{breadcrumb}</a>
      <span class="text-ink-muted">/</span>
      <span class="flex items-center gap-2">
        <span class:list={["w-1.5 h-1.5 rounded-full", categoryColorClass]}></span>
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.15em] text-ink-muted">{categoryLabel}</span>
      </span>
      <slot />
    </div>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-ink mb-3">{title}</h1>
    <p class="text-xl text-ink-light max-w-3xl">{tagline}</p>
    <div class="flex flex-wrap gap-2 mt-5">
      {tags.map((tag) => (
        <span class="font-mono text-[0.7rem] text-tag-text border border-border px-2 py-1 rounded-[2px]">{tag}</span>
      ))}
    </div>
  </div>
</section>

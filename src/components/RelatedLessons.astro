---
import LessonCard from '@/components/LessonCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lessons: CollectionEntry<'lessons'>[];
}

const { lessons } = Astro.props;
---

{lessons.length > 0 && (
  <section class="mb-10 p-5 bg-paper-warm border border-border rounded-xl">
    <div class="flex items-start justify-between gap-4 mb-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-1">Learn first</p>
        <h2 class="font-serif text-xl font-bold text-ink">Concepts behind this architecture</h2>
      </div>
      <a href="/lessons" class="hidden sm:inline-flex text-sm font-medium text-accent hover:text-accent-hover transition-colors">
        All lessons
      </a>
    </div>
    <div class="grid md:grid-cols-2 gap-4">
      {lessons.map((lesson) => <LessonCard lesson={lesson} compact />)}
    </div>
  </section>
)}

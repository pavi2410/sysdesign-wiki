---
interface Props {
  contentId: string;  // e.g. "lessons/caching"
  title: string;
  tagline: string;
  href: string;
  type: 'lesson' | 'guide' | 'system';
}

const { contentId, title, tagline, href, type } = Astro.props;
---

<div
  class="flex items-center gap-2 mt-6"
  data-reading-actions
  data-content-id={contentId}
  data-title={title}
  data-tagline={tagline}
  data-href={href}
  data-type={type}
>
  <!-- Mark as read toggle -->
  <button
    data-action="toggle-read"
    class="neuo-btn-ghost inline-flex items-center gap-2 px-3.5 py-2 rounded-[2px] text-sm font-medium border border-border text-ink-light hover:border-accent hover:text-accent transition-colors"
    aria-pressed="false"
  >
    <!-- Unread state -->
    <span class="read-off-state inline-flex items-center gap-2">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 8v4l3 3"/>
      </svg>
      Mark as read
    </span>
    <!-- Read state (hidden until active) -->
    <span class="read-on-state hidden inline-flex items-center gap-2 text-accent">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
        <path d="M22 4 12 14.01l-3-3"/>
      </svg>
      Read
    </span>
  </button>

  <!-- Save for later toggle -->
  <button
    data-action="toggle-list"
    class="neuo-btn-ghost inline-flex items-center gap-2 px-3.5 py-2 rounded-[2px] text-sm font-medium border border-border text-ink-light hover:border-accent hover:text-accent transition-colors"
    aria-pressed="false"
  >
    <!-- Unsaved state -->
    <span class="list-off-state inline-flex items-center gap-2">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m19 21-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
      Save for later
    </span>
    <!-- Saved state (hidden until active) -->
    <span class="list-on-state hidden inline-flex items-center gap-2 text-accent">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" stroke="none">
        <path d="m19 21-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
      Saved
    </span>
  </button>
</div>

<script>
  import { isRead, inList, toggleRead, toggleList } from '@/scripts/reading-store';

  function initReadingActions() {
    document.querySelectorAll<HTMLElement>('[data-reading-actions]').forEach((container) => {
      const id      = container.dataset.contentId!;
      const title   = container.dataset.title!;
      const tagline = container.dataset.tagline!;
      const href    = container.dataset.href!;
      const type    = container.dataset.type as 'lesson' | 'guide' | 'system';

      const readBtn = container.querySelector<HTMLButtonElement>('[data-action="toggle-read"]')!;
      const listBtn = container.querySelector<HTMLButtonElement>('[data-action="toggle-list"]')!;

      // ── Sync UI to current state ──────────────────────────────────────────
      function syncRead() {
        const read = isRead(id);
        readBtn.setAttribute('aria-pressed', String(read));
        readBtn.querySelector('.read-off-state')!.classList.toggle('hidden', read);
        readBtn.querySelector('.read-on-state')!.classList.toggle('hidden', !read);

        // When read, hide the list button (no need to save something already read)
        listBtn.classList.toggle('hidden', read);
      }

      function syncList() {
        const saved = inList(id);
        listBtn.setAttribute('aria-pressed', String(saved));
        listBtn.querySelector('.list-off-state')!.classList.toggle('hidden', saved);
        listBtn.querySelector('.list-on-state')!.classList.toggle('hidden', !saved);
      }

      syncRead();
      syncList();

      // ── Button handlers ───────────────────────────────────────────────────
      readBtn.addEventListener('click', () => {
        toggleRead({ id, title, tagline, href, type });
        syncRead();
        syncList(); // re-sync list in case markRead removed it from the list
      });

      listBtn.addEventListener('click', () => {
        toggleList({ id, title, tagline, href, type });
        syncList();
      });

      // ── React to cross-tab changes ────────────────────────────────────────
      window.addEventListener('storage', (e) => {
        if (e.key === 'sysdesign:read' || e.key === 'sysdesign:list') {
          syncRead();
          syncList();
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReadingActions);
  } else {
    initReadingActions();
  }
</script>

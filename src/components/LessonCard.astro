---
import { lessonCategoryColors, lessonCategoryLabels, lessonLevelLabels } from '@/lib/categories';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lesson: CollectionEntry<'lessons'>;
  compact?: boolean;
}

const { lesson, compact = false } = Astro.props;
const { title, tagline, category, level, timeMinutes, tags } = lesson.data;
const colorClass = lessonCategoryColors[category];
---

<a
  href={`/lessons/${lesson.id}`}
  class:list={[
    'neuo-raised group block bg-paper border border-border rounded-[2px] hover:border-accent hover:bg-paper-warm transition-colors duration-200',
    compact ? 'p-5' : 'p-6',
  ]}
>
  <div class="flex flex-wrap items-center gap-2 mb-3">
    <span class:list={["w-1.5 h-1.5 rounded-full shrink-0", colorClass]}></span>
    <span class="font-mono text-[0.65rem] uppercase tracking-[0.15em] text-ink-muted">
      {lessonCategoryLabels[category]}
    </span>
    <span class="font-mono text-[0.65rem] uppercase tracking-[0.15em] text-ink-muted border-l border-border pl-2">
      {lessonLevelLabels[level]}
    </span>
    <span class="font-mono text-[0.65rem] text-ink-muted">{timeMinutes} min</span>
  </div>
  <h3 class:list={['font-serif font-bold text-ink group-hover:text-accent transition-colors', compact ? 'text-lg' : 'text-xl']}>
    {title}
  </h3>
  <p class="text-sm text-ink-light leading-relaxed mt-2 mb-4">{tagline}</p>
  <div class="flex flex-wrap gap-1.5">
    {tags.slice(0, compact ? 3 : 4).map((tag) => (
      <span class="font-mono text-[0.7rem] text-tag-text border border-border px-1.5 py-0.5 rounded-[2px]">{tag}</span>
    ))}
  </div>
</a>

{
  "main": "@astrojs/cloudflare/entrypoints/server",
	"name": "system-design-wiki",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  }
}